# Agent Team CLI - Environment Variables
# Copy this file to .env before use: cp .env.example .env

# ============================================================
# GitHub Settings (for issue/PR management)
# ============================================================

# GitHub Personal Access Token
# - Classic PAT: repo (required) + project (optional, for Projects board) scopes
# - Fine-grained PAT: Issues, Contents, Pull requests write permissions under Repository permissions
GITHUB_TOKEN=ghp_xxxxx

# ============================================================
# Local Workspace Settings
# ============================================================
# The agent references existing code and saves generated code as local files.
# Configuration (in order of priority):
#
# 1) Specify in polymeld.config.yaml:
#    project:
#      local_path: ~/projects/my-app
#
# 2) Run polymeld from the target project directory for auto-detection:
#    cd ~/projects/my-app && polymeld start
#
# If not set, operates in GitHub API-only mode (without local files).
